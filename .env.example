# Variáveis de ambiente para execução local com Docker Compose
# Copie este arquivo para .env e preencha com seus valores

# Banco de dados PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=energift

# Connection string da aplicação (usado pelo docker-compose.yml)
CONNECTION_STRING=Host=postgres-db;Port=5432;Database=energift;Username=postgres;Password=postgres

# Ambiente da aplicação
ASPNETCORE_ENVIRONMENT=Development
